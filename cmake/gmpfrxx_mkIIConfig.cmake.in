@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
list(PREPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

find_dependency(GMP)
if(@GMPFRXX_MKII_ENABLE_MPFR@)
    find_dependency(MPFR)
endif()
if(@GMPFRXX_MKII_ENABLE_MPC@)
    find_dependency(MPC)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/gmpxx_mkIITargets.cmake")
if(@GMPFRXX_MKII_ENABLE_MPFR@)
    include("${CMAKE_CURRENT_LIST_DIR}/mpfrxx_mkIITargets.cmake")
endif()
if(@GMPFRXX_MKII_ENABLE_MPC@)
    include("${CMAKE_CURRENT_LIST_DIR}/mpcxx_mkIITargets.cmake")
    include("${CMAKE_CURRENT_LIST_DIR}/gmpfrxx_mkIITargets.cmake")
endif()

check_required_components(gmpfrxx_mkII)
